# deps / build output (regenerated by `npm install` / `npm run build`)
node_modules/
dist/
*.tsbuildinfo

# python cache
__pycache__/
*.pyc

# generated outputs (regenerate via CLI / MCP tools)
claude-status.html
config-report.html
*.export.html

# local snapshot store (default D:\.claude-snapshot; override via CLAUDE_SNAPSHOT_STORE)
.claude-snapshot/

# personal / machine-local
.claude/settings.local.json

# editor / OS
.DS_Store
Thumbs.db
*.log
